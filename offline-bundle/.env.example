# ═══════════════════════════════════════════════════════════════
# FirmClaw 环境变量配置示例
# ═══════════════════════════════════════════════════════════════
#
# 复制此文件为 .env 并修改下面的配置：
#   cp .env.example .env
#
# 【重要】环境变量优先级：
#   系统环境变量 > .env 文件 > 代码默认值
#
# 如果 Windows 系统环境变量中已设置 LLM_API_KEY，
# .env 中的值会被忽略。建议二选一使用：
#   1. 删除 .env 文件，直接使用系统环境变量
#   2. 或删除系统环境变量，使用 .env 文件
#
# 支持的 LLM 提供商（任选其一）：
#   - OpenAI、Claude、MiniMax、DeepSeek、Moonshot、硅基流动 等
#   - 任何兼容 OpenAI Chat Completions API 的服务都可以
# ═══════════════════════════════════════════════════════════════

# 【必需】LLM API 密钥
LLM_API_KEY=your-api-key-here

# 【必需】API 基础 URL（结尾不要带斜杠）
# 常用提供商：
#   - OpenAI:        https://api.openai.com/v1
#   - MiniMax:       https://api.minimax.chat/v1
#   - DeepSeek:      https://api.deepseek.com/v1
#   - Moonshot:      https://api.moonshot.cn/v1
#   - 硅基流动:       https://api.siliconflow.cn/v1
#   - 本地模型 (Ollama): http://localhost:11434/v1
LLM_BASE_URL=https://api.openai.com/v1

# 【必需】模型名称
# 常用模型：
#   - OpenAI:        gpt-4o, gpt-4o-mini, gpt-4-turbo
#   - MiniMax:       MiniMax-M2.7, abab6.5s-chat
#   - DeepSeek:      deepseek-chat, deepseek-coder
#   - Moonshot:      moonshot-v1-8k, moonshot-v1-32k
#   - 硅基流动:       Qwen/Qwen2-7B-Instruct, THUDM/glm-4-9b-chat
LLM_MODEL=gpt-4o-mini

# 【可选】其他配置
# ANTHROPIC_AUTH_TOKEN=       # 兼容 Claude Code 配置
# ANTHROPIC_BASE_URL=         # 兼容 Claude Code 配置
# ANTHROPIC_MODEL=            # 兼容 Claude Code 配置
